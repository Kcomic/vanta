{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/api/products",
      "headers": [{ "key": "cache-control", "value": "public, max-age=60" }]
    }
  ]
}
